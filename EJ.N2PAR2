{
    Console.WriteLine("Límite para Fibonacci:");
    int limite = int.Parse(Console.ReadLine());
    int fib1 = 0, fib2 = 1, fib3 = 0;

    while (fib1 < limite)
    {
        Console.Write(fib1 + " ");
        fib3 = fib1 + fib2;
        fib1 = fib2;
        fib2 = fib3;
    }
    Console.WriteLine();
}

